    \node[fill=accentl, inner xsep=9pt, inner ysep=5pt,
          text width=\dimexpr\linewidth-18pt\relax, anchor=north west] at (0,0) {%
      \gtfamily\bfseries\large{\color{accent}\rule[-0.4mm]{1.8mm}{3.8mm}}\ \textcolor{accentd}{#1}%
    };
    \fill[accent] (0,-0.2mm) rectangle (\linewidth,0.4mm);
  \end{tikzpicture}\par\vspace{2mm}
}

