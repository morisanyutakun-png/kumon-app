%% kumonprint.sty (v6) — 小学部 反復学習プリント用スタイル
%% 中高部の設計システム iplus-sheet / iplus-figs を「継承」し、小学部向けに
%% やさしく(大きめ・ゴシック・ノビットブルー)調整したスキン。
%% 既存マクロ(\kpprompt, \kpsheet, \kpitem, \kpbox, \kpgraph 等)は据え置き、
%% 見た目だけ中高部の角張ったアクセント意匠へ揃える。
%%
%% コンパイル: lualatex (luatexja-preset / haranoaji)。
%% 解答版は \def\ANSWER{1} を定義してからコンパイルすると答えが色字で出る。
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{kumonprint}[2026/06/27 Nobit elementary worksheet v6 (iplus-derived)]

\RequirePackage{iplus-sheet}   % 中高部の共通デザイン(角張りアクセント・ヘッダー・解答欄)
\RequirePackage{iplus-figs}    % 図ツールキット
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{multicol}
\RequirePackage{enumitem}
\RequirePackage{array}

% ===== 小学部プリセット ==============================================
