% ===== とけい =======================================================
\newcommand{\kpclock}[2]{%
  \begin{tikzpicture}
    \draw[fill=white,line width=1.2pt] (0,0) circle (1cm);
    \foreach \i in {1,...,12}{%
      \node[font=\gtfamily\scriptsize] at ({90-30*\i}:0.78cm) {\i};%
      \draw[line width=0.6pt] ({90-30*\i}:0.92cm) -- ({90-30*\i}:1cm);%
    }
    \draw[line width=1.8pt, inkgray] (0,0) -- ({90-30*#1-0.5*#2}:0.5cm);
    \draw[line width=1pt, kpink] (0,0) -- ({90-6*#2}:0.82cm);
    \fill (0,0) circle (1.2pt);
  \end{tikzpicture}%
}

% ===== 絵(かぞえる用) ===============================================
\newcommand{\kpcube}[2]{%
  \begin{scope}[shift={(#1,#2)}]
    \fill[kpcubef] (0,0) rectangle (1,1);
    \fill[kpcubet] (0,1) -- (0.32,1.32) -- (1.32,1.32) -- (1,1) -- cycle;
    \fill[kpcuber] (1,0) -- (1.32,0.32) -- (1.32,1.32) -- (1,1) -- cycle;
    \draw[accent,line width=1pt] (0,0) rectangle (1,1);
    \draw[accent,line width=1pt] (0,1) -- (0.32,1.32) -- (1.32,1.32) -- (1,1);
    \draw[accent,line width=1pt] (1,0) -- (1.32,0.32) -- (1.32,1.32);
  \end{scope}%
}
\newcommand{\kpball}[3]{%
