% ===== なまえ / ひづけ / てんすう 欄 =================================
\newcommand{\kpnamebar}{%
  \noindent\begin{tikzpicture}
    \node[draw=accent, line width=0.7pt, fill=white, inner xsep=8pt, inner ysep=6pt,
          text width=\dimexpr\linewidth-16pt\relax, anchor=north west] at (0,0) {%
      {\gtfamily
        なまえ \tikz[baseline=-2.4mm]{\node[draw=kpline,fill=white,minimum width=52mm,minimum height=7.5mm]{};}\hfill
        ひづけ \rule{8mm}{0.4pt}\,がつ\,\rule{8mm}{0.4pt}\,にち \hfill
        てんすう \tikz[baseline=-2.4mm]{\node[draw=kpstar,fill=white,line width=1pt,minimum width=18mm,minimum height=7.5mm]{};}%
      }%
    };
  \end{tikzpicture}\par\vspace{3mm}
}

% ===== きょうの めあて ===============================================
\newcommand{\kpgoal}[1]{%
