}

% ===== セクション見出し(角張り・アクセント) ==========================
\newif\ifkpfirstsec \kpfirstsectrue
\newcommand{\kpsection}[1]{%
  \ifkpfirstsec\kpfirstsecfalse\else\par\vspace{\stretch{1}}\fi
  \vspace{1mm}\par
