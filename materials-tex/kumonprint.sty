% =====================================================================
%  問題/解答欄の2段組(文章題・概念プリント用)
%   各 \kpQ は本文の縦リスト中に「左=問題 / 右=解答欄」の1行を出力し、
%   行間に \vspace{\stretch{1}} を入れて紙面を縦いっぱいに均等配置する。
% =====================================================================
\newsavebox{\kpLbox}
\newlength{\kpLh}
\newlength{\kpLw}
\newlength{\kpRw}
\newlength{\kpminans}\setlength{\kpminans}{15mm}

\newcommand{\kpqlabel}[1]{\colorbox{accent}{\makebox[8mm][c]{\gtfamily\bfseries\textcolor{white}{#1}}}}
\newlength{\kpqgut}\setlength{\kpqgut}{11mm}  % 番号ラベルの左ガター幅

\newenvironment{kpsheet}{%
  \par\setlength{\kpLw}{0.585\linewidth}\setlength{\kpRw}{0.350\linewidth}%
  \par\nobreak\vspace{\stretch{1}}%
}{%
  \par
}
%% 1問  \kpQ{番号}{問題本文}{解答欄(中身は \kpAR の列)}
\newcommand{\kpQ}[3]{%
  % 番号は左の固定ガター、問題文は右ブロック(折り返しは番号の下に来ずに揃う)。
  \sbox{\kpLbox}{\begin{minipage}[t]{\kpLw}%
      \begin{minipage}[t]{\kpqgut}\kpqlabel{#1}\end{minipage}%
      \begin{minipage}[t]{\dimexpr\kpLw-\kpqgut\relax}{\large #2}\end{minipage}%
    \end{minipage}}%
  \setlength{\kpLh}{\dimexpr\ht\kpLbox+\dp\kpLbox\relax}%
  \ifdim\kpLh<\kpminans\setlength{\kpLh}{\kpminans}\fi
  \noindent\usebox{\kpLbox}\hfill
  \begin{minipage}[t]{\kpRw}%
    \setlength{\fboxsep}{6pt}\setlength{\fboxrule}{0.8pt}%
    \fcolorbox{accent}{white}{%
      \begin{minipage}[t][\dimexpr\kpLh-2\fboxsep\relax]{\dimexpr\kpRw-2\fboxsep-2\fboxrule\relax}%
        #3%
      \end{minipage}}%
  \end{minipage}\par
  \nobreak\vspace{\stretch{1}}%
}
%% 解答欄の1行  \kpAR{ラベル}{こたえ}
\newcommand{\kpAR}[2]{%
  \par\noindent{\footnotesize\textcolor{inkgray}{#1}}\ifx\relax#1\relax\else\ \fi\ifkpans\textcolor{kpink}{\bfseries #2}\else\phantom{#2}\fi\par
  \vspace{0.8mm}\textcolor{kpline}{\rule{\linewidth}{0.3pt}}\par\vspace{1.2mm}%
}
%% 解答欄のコンパイル行(multicols 用)。番号+こたえ。
\newcommand{\kpARc}[2]{%
  \noindent{\scriptsize\textcolor{inkgray}{#1}}\,\ifkpans\textcolor{kpink}{\bfseries #2}\else\phantom{99}\fi\par\vspace{2.0mm}%
}
%% 左の番号付き計算項目(multicols 用)。
\newcommand{\kpLc}[2]{\noindent{\gtfamily\footnotesize\textcolor{accent}{#1}}\ {#2}\par\vspace{1.7mm}}

%% 番号タイル(角張りアクセント = iplus \qnum)。見出しの大番号用。
\newcommand{\kpnumtile}[1]{\qnum{#1}}
%% アイプラス風の番号付き見出し(全幅・インライン解答用)。\kpprompt{1}{つぎの…}
\newcommand{\kpprompt}[2]{%
  \par\vspace{0.5mm}
  \raisebox{0pt}[3.8mm][1.2mm]{\kpnumtile{#1}}\hspace{2.5mm}{\gtfamily\bfseries\large\textcolor{accentd}{#2}}\par
  \vspace{1.4mm}{\color{accent}\hrule height 0.7pt}\par\vspace{2.6mm}%
}

%% 10のまとまり(テンフレーム)。\kptenframe{ぬる数} (0〜10)
\newcommand{\kptenframe}[1]{%
  \begin{tikzpicture}[scale=0.42]
    \foreach \c in {0,...,4}{
      \draw[accent,line width=1pt] (\c,0) rectangle (\c+1,1);
      \draw[accent,line width=1pt] (\c,1) rectangle (\c+1,2);
    }
    \foreach \i in {1,...,#1}{
      \pgfmathtruncatemacro{\row}{(\i-1)/5}
      \pgfmathtruncatemacro{\col}{mod(\i-1,5)}
      \fill[accent] (\col+0.5, 1.5-\row) circle (0.34);
    }
  \end{tikzpicture}%
}

% =====================================================================
%  テンプレ拡張部品(小問の入れ子・図/グラフ枠・数直線・座標/棒グラフ)
% =====================================================================
\usetikzlibrary{arrows.meta,plotmarks}

%% 小問: 1つの \kpQ の中に (1)(2)… を縦に並べる。
\newcommand{\kpsubq}[2]{%
  \par\vspace{0.6mm}\noindent
  \makebox[8mm][l]{\gtfamily\bfseries\textcolor{accentd}{#1}}%
  \begin{minipage}[t]{\dimexpr\linewidth-8mm\relax}#2\end{minipage}\par\vspace{1.2mm}%
}

%% 自由に かく ための 白い 枠(図示・作図用)。\kpfigbox{高さ}
\newcommand{\kpfigbox}[1]{%
  \par\noindent\setlength{\fboxsep}{4pt}\setlength{\fboxrule}{0.8pt}%
  \fcolorbox{accent}{white}{\begin{minipage}[t][#1]{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}\ \end{minipage}}\par%
}

%% 方眼(cols × rows のマス目)。\kpsquares{列}{行}
\newcommand{\kpsquares}[2]{%
  \begin{tikzpicture}[x=6mm,y=6mm,line cap=round]
    \draw[kpline,line width=0.4pt] (0,0) grid (#1,#2);
    \draw[accent,line width=0.9pt] (0,0) rectangle (#1,#2);
  \end{tikzpicture}%
}

%% 座標グラフの土台(cols × rows、O・矢印つき)。中の座標はマス目単位。
\newenvironment{kpgraph}[2]{%
  \begin{center}\begin{tikzpicture}[x=7mm,y=7mm,line cap=round,line join=round]
    \draw[kpline,line width=0.4pt] (0,0) grid (#1,#2);
    \draw[inkgray,line width=1pt,-{Stealth[length=2.2mm]}] (0,0) -- (#1+0.45,0);
    \draw[inkgray,line width=1pt,-{Stealth[length=2.2mm]}] (0,0) -- (0,#2+0.45);
    \node[below left,font=\gtfamily\scriptsize,inkgray] at (0,0) {O};
}{%
  \end{tikzpicture}\end{center}%
}
\newcommand{\kpgx}[2]{\node[below,font=\gtfamily\scriptsize,inkgray] at (#1,-0.12) {#2};}
\newcommand{\kpgy}[2]{\node[left,font=\gtfamily\scriptsize,inkgray] at (-0.12,#1) {#2};}
\newcommand{\kpgline}[1]{%
  \draw[accent,line width=1.3pt] plot[mark=*,mark size=1.7pt,mark options={fill=accent,draw=accent}] coordinates {#1};%
}
\newcommand{\kpgbar}[2]{%
  \fill[accent!40] (#1-0.32,0) rectangle (#1+0.32,#2);
  \draw[accentd,line width=0.8pt] (#1-0.32,0) rectangle (#1+0.32,#2);%
}

%% 数直線。\kpnumberline{最小}{最大}{きざみ}(全幅に合わせて自動縮尺)
\newcommand{\kpnumberline}[3]{%
  \edef\kpnlb{\the\numexpr#1+#3\relax}%
  \pgfmathsetmacro{\kpnlux}{150/(#2-#1)}%
  \begin{center}\begin{tikzpicture}[x=\kpnlux mm,line cap=round]
